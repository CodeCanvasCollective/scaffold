{{#if features.tailwind}}
@tailwind base;
@tailwind components;
@tailwind utilities;
{{else}}
:root {
  font-family: Inter, system-ui, Avenir, Helvetica, Arial, sans-serif;
  color: #213547;
  background-color: #ffffff;
}

body {
  margin: 0;
  min-height: 100vh;
  padding: 2rem;
}

h1 {
  font-size: 3.2em;
  line-height: 1.1;
}
{{/if}}
